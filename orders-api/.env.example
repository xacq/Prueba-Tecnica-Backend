# Servidor
PORT=3002
NODE_ENV=development

# Base de datos (XAMPP local)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=backoffice
DB_USER=root
DB_PASS=

# Auth
JWT_SECRET=dev-jwt-secret-cambia-en-produccion
SERVICE_TOKEN=dev-service-token

# URL interna de Customers API (para validar clientes al crear órdenes)
# En local: apunta a localhost porque Orders corre fuera de Docker
# En Docker Compose: usar el nombre del servicio → http://customers-api:3001
CUSTOMERS_INTERNAL_URL=http://localhost:3001
