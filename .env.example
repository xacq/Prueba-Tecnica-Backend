# ── Variables para docker-compose ────────────────────────────
# Copiar a .env en la raíz del monorepo antes de levantar

MYSQL_ROOT_PASSWORD=secret
MYSQL_DATABASE=backoffice

NODE_ENV=production

# Debe ser igual en todos los servicios y el Lambda
JWT_SECRET=cambia-esto-en-produccion-min-32-chars
SERVICE_TOKEN=cambia-esto-en-produccion-token-seguro
