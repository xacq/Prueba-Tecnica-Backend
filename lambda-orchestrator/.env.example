# ── APIs downstream ────────────────────────────────────────────────
# En local: Lambda corre fuera de Docker, usa localhost
CUSTOMERS_API_BASE=http://localhost:3001
ORDERS_API_BASE=http://localhost:3002

# En AWS: URL pública de cada API desplegada
# CUSTOMERS_API_BASE=https://tu-customers-api.ejemplo.com
# ORDERS_API_BASE=https://tu-orders-api.ejemplo.com

# ── Auth entre servicios ───────────────────────────────────────────
# Debe coincidir con SERVICE_TOKEN en customers-api y orders-api
SERVICE_TOKEN=dev-service-token

# ── Base de datos para idempotency_keys ────────────────────────────
# En local: el Lambda alcanza MySQL expuesto por Docker Compose en 3306
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=backoffice
DB_USER=root
DB_PASS=secret
